# 28. Advanced Patterns

## Discriminated Union

``` ts
type Shape =
  | { type:"circle"; radius:number }
  | { type:"square"; size:number }

function area(shape: Shape){

  switch(shape.type){

    case "circle":
      return Math.PI * shape.radius ** 2

    case "square":
      return shape.size ** 2
  }

}
```


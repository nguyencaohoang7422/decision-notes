------------------------------------------------------------------------

# 19. Generics

Generic function:

``` ts
function identity<T>(value: T): T {
  return value
}
```

Usage:

``` ts
identity<number>(5)
identity<string>("hello")
```

------------------------------------------------------------------------

# 20. Generic Constraints

``` ts
function lengthOf<T extends { length: number }>(arg: T) {
  return arg.length
}
```

------------------------------------------------------------------------

# 21. keyof

``` ts
type User = {
  id: number
  name: string
}

type Keys = keyof User
```

Result:

    "id" | "name"

------------------------------------------------------------------------

# 22. typeof

``` ts
const user = {
  id: 1,
  name: "alex"
}

type User = typeof user
```

------------------------------------------------------------------------

# 23. Utility Types

## Partial

``` ts
type PartialUser = Partial<User>
```

## Pick

``` ts
type NameOnly = Pick<User, "name">
```

## Omit

``` ts
type WithoutAge = Omit<User, "age">
```

## Record

``` ts
type UserRoles = Record<string, string>
```

------------------------------------------------------------------------

# 24. Mapped Types

``` ts
type ReadOnly<T> = {
  readonly [K in keyof T]: T[K]
}
```

------------------------------------------------------------------------

# 25. Conditional Types

``` ts
type IsString<T> = T extends string ? true : false
```

------------------------------------------------------------------------

# 26. Template Literal Types

``` ts
type Event = "click" | "hover"

type EventHandler = `on${Capitalize<Event>}`
```

Result:

    onClick | onHover

------------------------------------------------------------------------

# 27. Modules

Export:

``` ts
